# ─── Serveur ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://127.0.0.1:3000
FRONTEND_URL=http://localhost:4200

# ─── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=tun_job_portal

# ─── JWT (générer une clé longue aléatoire en production) ──
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h

# ─── SMTP (Nodemailer) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
MAIL_FROM_NAME=Tun-Job Portal
MAIL_FROM_ADDRESS=no-reply@tunjob.tn

# ─── Uploads (octets) ──────────────────────────────────────
UPLOAD_MAX_AVATAR_BYTES=2097152
UPLOAD_MAX_CV_BYTES=5242880
